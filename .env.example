BOT_TOKEN=...
KIE_API_KEY=...
GOOGLE_API_KEY=...
IMAGE_PROVIDER=...
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Heartbeat / Watchdog (Railway: основной сервис `python main.py`, второй — `python watchdog.py`)
# Отдельный бот @BotFather → только отправка алертов админу
# WATCHDOG_BOT_TOKEN=...
# ADMIN_TG_ID=123456789
# ALERT_CHAT_IDS=123456789,-1009876543210

# PostgreSQL backup → Cloudflare R2 (backup.py)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# BACKUP_RETENTION_DAYS=7
# BACKUP_R2_PREFIX=postgres/
# BACKUP_NOTIFY_CHAT_ID=-1001234567890   # ID группы для уведомлений (бот должен быть в группе)

# Crypto Pay (@CryptoBot): https://pay.crypt.bot/api
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_API_BASE=https://pay.crypt.bot/api

# Опционально: JSON пакетов для Crypto Pay fiat (ключи s,m,l,xl,xxl). По умолчанию — ТЗ в app/packages.py (BANANA_PACKAGES_DEFAULT).
# BANANA_PACKAGES={"s":{"bananas":10,"usdt":"1.49"},"m":{"bananas":44,"usdt":"4.49"}}

# Crypto Pay (ТЗ): POST http://<host>:5001/webhooks/crypto-pay

# Яндекс.Метрика: офлайн-покупки (OAuth), BOT_START — Measurement Protocol (/collect/)
# YANDEX_METRICA_COUNTER_ID=106049387
# YANDEX_METRICA_TOKEN=
# YANDEX_METRICA_MS_TOKEN=
# YANDEX_METRICA_ENABLED=true
# YANDEX_METRICA_BOT_START_TARGET=telegram_bot_start
YANDEX_METRICA_MS_TOKEN=675750e3-df80-4b7e-8cc3-cc074992db9f